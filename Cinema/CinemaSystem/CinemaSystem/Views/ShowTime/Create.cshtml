@model CinemaSystem.ViewModels.ShowTimeVM

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>ShowTime</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
       
            <div class="form-group">
                <label class="control-label">Chosse Movie</label>
                <select asp-for="MovieId" class="form-control" asp-items="@(new SelectList(Model.movies, "Id", "Title"))"></select>
            </div>
            <div class="form-group">
                <label  class="control-label">Chosse Hall</label>
                <select asp-for="HallId" class="form-control" asp-items="@(new SelectList(Model.halls,"Id" , "Name"))"></select>
               
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
