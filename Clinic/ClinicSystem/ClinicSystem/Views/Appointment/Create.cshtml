@model ClinicSystem.ViewModels.AppointmentVm

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>AppointmentVm</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="DocId" class="control-label"></label>
                <select asp-for="DocId" class="form-control">
                    @foreach (var doctor in Model.doctors)
                    {
                        <option value="@doctor.DoctorID">@doctor.DoctorName</option>
                    }
                </select>
                <span asp-validation-for="DocId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PatId" class="control-label"></label>
                <select class="form-control" asp-for="PatId">
                    @foreach (var doctor in Model.patients)
                    {
                        <option value="@doctor.PatientID">@doctor.PatientName</option>
                    }
                </select>
                <span asp-validation-for="PatId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="control-label"></label>
                 <input asp-for="Notes " class="form-control"/>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Date" class="control-label"></label>
                 <input asp-for="Date" class="form-control"/>
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>


            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
