@model Vehicle_System.View_Model.MaintenanceRecordVm

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>MaintenanceRecordVm</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="VehicleId" class="control-label"></label>
                <select asp-for="VehicleId" class="form-control" >
                    <option value="">-- Select Vehicle --</option>
                    @foreach (var vehicle in Model.Vehicles)
                    {
                        <option value="@vehicle.VehicleId">  @vehicle.Model </option>
                    }
                </select>
                <span asp-validation-for="VehicleId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ServiceDate" class="control-label"></label>
                <input asp-for="ServiceDate" class="form-control" />
                <span asp-validation-for="ServiceDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentKm" class="control-label"></label>
                <input asp-for="CurrentKm" class="form-control" />
                <span asp-validation-for="CurrentKm" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Notes" class="control-label"></label>
                <input asp-for="Notes" class="form-control" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="MaintenanceTypeId" class="control-label"></label>
                <select asp-for="MaintenanceTypeId" class="form-control">
                    <option value="">-- Select Maintenance Type --</option>
                    @foreach (var maintenanceType in Model.MaintenanceTypes)
                    {
                        <option value="@maintenanceType.MaintenanceTypeId">  @maintenanceType.Name </option>
                    }
                </select>
                <span asp-validation-for="MaintenanceTypeId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
